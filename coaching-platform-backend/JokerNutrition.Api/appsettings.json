{
  "ConnectionStrings": {
    "DefaultConnection": "Host=your-production-db-host;Database=JokerNutrition;Username=your_username;Password=your_password"
  },
  "CorsAllowedOrigins": [
    "https://your-production-app.com"
  ],
  "BlobStorageSettings": {
    "ConnectionString": "YOUR_AZURE_BLOB_STORAGE_CONNECTION_STRING",
    "ContainerName": "joker-progress-photos",
    "LocalFallbackBaseUrl": "https://your-production-api.com"
  },
  "AzureStorage": {
    "ContainerName": "joker-nutrition",
    "MaxFileSizeInBytes": 10485760
  },
  "JwtSettings": {
    "SecretKey": "YOUR_JWT_256BIT_SECRET_KEY_FOR_PRODUCTION",
    "Issuer": "https://your-production-api.com",
    "Audience": "https://your-production-api.com",
    "ExpiryInDays": 1
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "SmtpSettings": {
    "Host": "YOUR_SMTP_HOST",
    "Port": 587,
    "UseSsl": true,
    "Username": "YOUR_SMTP_USERNAME",
    "Password": "YOUR_SMTP_PASSWORD",
    "FromEmail": "noreply@yourdomain.com",
    "FromName": "Joker Nutrition",
    "SignUpBaseUrl": "https://your-production-app.com/join-the-team",
    "SupportEmail": "support@yourdomain.com"
  },
  "AppSettings": {
    "ResetPasswordPageUrl": "https://your-production-app.com/reset-password"
  },
  "IpRateLimiting": {
    "EnableEndpointRateLimiting": true,
    "StackBlockedRequests": false,
    "RealIpHeader": "X-Real-IP",
    "HttpStatusCode": 429,
    "GeneralRules": [
      { "Endpoint": "post:/api/auth/forgot-password", "Period": "1h", "Limit": 3 },
      { "Endpoint": "post:/api/auth/login", "Period": "1m", "Limit": 10 }
    ]
  }
}
