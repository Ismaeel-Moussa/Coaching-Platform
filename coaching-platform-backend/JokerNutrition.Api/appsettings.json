{
  "ConnectionStrings": {
    "DefaultConnection": "Host=your-production-db-host;Database=JokerNutrition;Username=your_username;Password=your_password"
  },
  "CorsAllowedOrigins": [
    "https://jokernutrition.app",
    "https://www.jokernutrition.app"
  ],
  "BlobStorageSettings": {
    "ConnectionString": "YOUR_AZURE_BLOB_STORAGE_CONNECTION_STRING",
    "ContainerName": "joker-progress-photos",
    "LocalFallbackBaseUrl": "https://your-production-api.com"
  },
  "AzureStorage": {
    "ContainerName": "joker-nutrition",
    "MaxFileSizeInBytes": 10485760
  },
  "JwtSettings": {
    "SecretKey": "YOUR_JWT_256BIT_SECRET_KEY_FOR_PRODUCTION",
    "Issuer": "https://your-production-api.com",
    "Audience": "https://your-production-api.com",
    "ExpiryInDays": 1
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "SmtpSettings": {
    "ResendApiKey": "re_your_resend_api_key_here",
    "FromEmail": "noreply@jokernutrition.app",
    "FromName": "Joker Nutrition",
    "SignUpBaseUrl": "https://jokernutrition.app/join-the-team",
    "SupportEmail": "support@jokernutrition.app"
  },
  "AppSettings": {
    "ResetPasswordPageUrl": "https://jokernutrition.app/reset-password"
  },
  "IpRateLimiting": {
    "EnableEndpointRateLimiting": true,
    "StackBlockedRequests": false,
    "RealIpHeader": "X-Real-IP",
    "HttpStatusCode": 429,
    "GeneralRules": [
      { "Endpoint": "post:/api/auth/forgot-password", "Period": "1h", "Limit": 3 },
      { "Endpoint": "post:/api/auth/login", "Period": "1m", "Limit": 10 }
    ]
  }
}
